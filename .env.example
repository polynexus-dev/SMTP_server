# ---- Copy to .env and edit everything marked CHANGEME ----
MAIL_DOMAIN=example.com            # your mail domain (user@MAIL_DOMAIN)
MAIL_HOSTNAME=mail.example.com     # MX hostname; must have matching A + PTR records

POSTGRES_DB=mailstack
POSTGRES_USER=mailstack
POSTGRES_PASSWORD=CHANGEME-strong-password
# Read-only SQL account used by Postfix/Dovecot lookup maps:
SQL_RO_USER=mailro
SQL_RO_PASSWORD=CHANGEME-another-password

DJANGO_SECRET_KEY=CHANGEME-50-random-chars
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=mail.example.com

DATABASE_URL=postgres://mailstack:CHANGEME-strong-password@postgres:5432/mailstack
REDIS_URL=redis://redis:6379/0

# Dovecot master user: lets the webmail open any mailbox with one service credential.
DOVECOT_MASTER_USER=webmail
DOVECOT_MASTER_PASSWORD=CHANGEME-master-secret

# Submission account Django uses to send outbound mail through Postfix.
SUBMISSION_USER=noreply@example.com
SUBMISSION_PASSWORD=CHANGEME-submission-secret

# Optional smarthost if your provider blocks port 25 (leave empty to send direct):
RELAYHOST=
RELAYHOST_USER=
RELAYHOST_PASSWORD=
